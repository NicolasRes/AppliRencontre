{% extends 'base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/app_design.css') }}">
{% endblock %}

{% block body %}
    {# Affichage des messages flash (succès ou erreur) #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash-popup flash-{{ label }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="app-body-reset">
        <div id="date-app-container">
            
            <aside class="sidebar">
                <h1 style="color: #ed3692; margin-bottom: 30px; font-family: sans-serif;">Tindr Modération</h1>
                {{ include('partials/_header_moderateur.html.twig') }}
            </aside>

            <main class="main-content" style="flex-direction: row; gap: 40px; padding: 40px; align-items: flex-start;">
                
                {% if signalements is empty %}
                    <div style="width: 100%; text-align: center; margin-top: 50px;">
                        <h2 style="color: white;">✅ Aucun signalement à traiter pour le moment.</h2>
                    </div>
                {% else %}
                    {# Pour l'instant on affiche le premier signalement de la file d'attente #}
                    {% set s = signalements|first %}
                    
                    <div style="display: flex; flex-direction: column; align-items: center; gap: 20px;">
                        <h2 style="color: white; text-shadow: 1px 1px 2px rgba(0,0,0,0.5); margin: 0;">Profil Signalé</h2>
                        
                        <div class="profile-card" style="position: relative; width: 350px; height: 500px; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.5);">
                            <img src="{{ s.cible.imageIdentite ? asset('images/' ~ s.cible.imageIdentite) : asset('images/PlaceHolderProfil.jpg') }}" alt="Cible" style="width: 100%; height: 100%; object-fit: cover;">
                            
                            <div style="position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(0,0,0,0.9), transparent); padding: 30px 20px 20px; color: white;">
                                <h3 style="margin: 0; font-size: 1.5em;">{{ s.cible.pseudo }}</h3>
                                <div style="display: inline-block; background: #ed3692; color: white; padding: 5px 10px; border-radius: 15px; font-size: 0.8em; margin-top: 10px;">
                                    ⚠️ Motif : {{ s.motif }}
                                </div>
                                <p style="margin: 10px 0 0; font-size: 0.9em; color: #ddd;">
                                    Signalé par : <strong>{{ s.auteur.pseudo }}</strong><br>
                                    Le : {{ s.dateS|date('d/m/Y à H:i') }}
                                </p>
                            </div>
                        </div>

                        {# --- 💡 MISE À JOUR ICI : UTILISATION DES IMAGES DE LIKE/DISLIKE --- #}
                        <div style="display: flex; gap: 20px; margin-top: 10px;">
                            {# Bouton IGNORER (reprend le visuel du LIKE/VALIDER) #}
                            <a href="{{ path('app_moderateur_ignorer', {'id': s.id}) }}" class="action-btn" title="Ignorer (Faux signalement)">
                                <img class="bg" src="{{ asset('images/green.webp') }}" alt="Vert">
                                <img class="icon" src="{{ asset('images/valid.webp') }}" alt="Valider">
                            </a>
                            
                            {# Bouton BANNIR (reprend le visuel du DISLIKE/REFUSER) #}
                            <a href="{{ path('app_moderateur_bannir', {'id': s.id}) }}" class="action-btn" title="Bannir le profil">
                                <img class="bg" src="{{ asset('images/Red.jpg') }}" alt="Rouge">
                                <img class="icon" src="{{ asset('images/Denied.jpg') }}" alt="Refuser">
                            </a>
                        </div>
                        {# ------------------------------------------------------------------ #}

                    </div>

                    <div style="flex: 1; background: white; border-radius: 20px; height: 600px; display: flex; flex-direction: column; box-shadow: 0 10px 25px rgba(0,0,0,0.2); overflow: hidden;">
                        <div style="background: #f8f9fa; padding: 15px; border-bottom: 1px solid #ddd; display: flex; align-items: center; gap: 15px;">
                            <strong style="color: #333;">Conversation entre {{ s.auteur.pseudo }} et {{ s.cible.pseudo }}</strong>
                        </div>

                        <div style="flex: 1; padding: 20px; background: #fff1f5; overflow-y: auto; display: flex; flex-direction: column; gap: 15px;">
                            <div style="text-align: center; color: #999; font-size: 0.8em;">-- Début de la discussion --</div>
                            
                            <div style="align-self: flex-start; background: white; padding: 10px 15px; border-radius: 15px; color: #555;">
                                [Placeholder] Les messages seront récupérés ici via une relation.
                            </div>
                        </div>

                        <div style="padding: 15px; background: white; border-top: 1px solid #ddd; text-align: center; color: #999; font-style: italic; font-size: 0.9em;">
                            Seuls les messages liés à cette rencontre sont affichés.
                        </div>
                    </div>
                {% endif %}
            </main>
        </div>
    </div>
{% endblock %}