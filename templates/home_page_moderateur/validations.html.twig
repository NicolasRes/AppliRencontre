{% extends 'base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/app_design.css') }}">
{% endblock %}

{% block body %}
    {# Affichage des messages flash (succès ou erreur) #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash-popup flash-{{ label }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="app-body-reset">
        <div id="date-app-container">
            
            <aside class="sidebar">
                <h1 style="color: #ed3692; margin-bottom: 30px; font-family: sans-serif;">Tindr Modération</h1>
                {{ include('partials/_header_moderateur.html.twig') }}
            </aside>

            <main class="main-content" style="flex-direction: row; gap: 40px; padding: 40px; align-items: flex-start;">
                
                {% if utilisateurs is empty %}
                    <div style="width: 100%; text-align: center; margin-top: 50px;">
                        <h2 style="color: white;">✅ Aucun profil en attente de validation.</h2>
                    </div>
                {% else %}
                    {# On affiche le premier utilisateur de la file d'attente #}
                    {% set u = utilisateurs|first %}
                    
                    <div style="display: flex; flex-direction: column; align-items: center; gap: 20px;">
                        <h2 style="color: white; text-shadow: 1px 1px 2px rgba(0,0,0,0.5); margin: 0;">Validation Requise</h2>
                        
                        <div class="profile-card" style="position: relative; width: 350px; height: 500px; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.5); background-color: #2d2d2d;">
                            {# On affiche la photo d'identité si elle existe #}
                            <img src="{{ u.imageIdentite ? asset('images/' ~ u.imageIdentite) : asset('images/PlaceHolderProfil.jpg') }}" alt="Identité" style="width: 100%; height: 100%; object-fit: cover;">
                            
                            <div style="position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(0,0,0,0.9), transparent); padding: 30px 20px 20px; color: white;">
                                <h3 style="margin: 0; font-size: 1.5em;">{{ u.pseudo }}</h3>
                                <div style="display: inline-block; background: #ed3692; color: white; padding: 5px 10px; border-radius: 15px; font-size: 0.8em; margin-top: 10px;">
                                    ⏳ En attente
                                </div>
                                <p style="margin: 10px 0 0; font-size: 0.9em; color: #ddd;">
                                    Email : <strong>{{ u.email }}</strong>
                                </p>
                            </div>
                        </div>

                        <div style="display: flex; gap: 20px; margin-top: 10px;">
                            {# Bouton VERT (Gauche) - Formulaire POST #}
                            <form action="{{ path('app_moderateur_valider', {'id': u.id}) }}" method="POST" style="margin: 0;">
                                <button type="submit" class="action-btn" title="Valider le profil" style="border: none; background: transparent; padding: 0; cursor: pointer;">
                                    <img class="bg" src="{{ asset('images/green.webp') }}" alt="Vert">
                                    <img class="icon" src="{{ asset('images/valid.webp') }}" alt="Valider">
                                </button>
                            </form>

                            {# Bouton ROUGE (Droite) - Formulaire POST #}
                            <form action="{{ path('app_moderateur_refuser', {'id': u.id}) }}" method="POST" style="margin: 0;">
                                <button type="submit" class="action-btn" title="Refuser le profil" style="border: none; background: transparent; padding: 0; cursor: pointer;">
                                    <img class="bg" src="{{ asset('images/Red.jpg') }}" alt="Rouge">
                                    <img class="icon" src="{{ asset('images/Denied.jpg') }}" alt="Refuser">
                                </button>
                            </form>
                        </div>
                    </div>

                    {# Panneau de droite : Informations détaillées du profil #}
                    <div style="flex: 1; background: white; border-radius: 20px; height: 600px; display: flex; flex-direction: column; box-shadow: 0 10px 25px rgba(0,0,0,0.2); overflow: hidden;">
                        <div style="background: #f8f9fa; padding: 15px; border-bottom: 1px solid #ddd; display: flex; align-items: center; gap: 15px;">
                            <strong style="color: #333;">Détails du profil de {{ u.pseudo }}</strong>
                        </div>

                        <div style="flex: 1; padding: 30px; background: #fff1f5; overflow-y: auto; display: flex; flex-direction: column; gap: 25px;">
                            
                            <div style="text-align: center; color: #ed3692; font-weight: bold; font-size: 1.1em; border-bottom: 2px solid rgba(237, 54, 146, 0.2); padding-bottom: 10px;">
                                Informations d'état civil
                            </div>

                            {% if profilCible %}
                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; font-size: 1.1em; color: #444;">
                                    <div style="background: white; padding: 15px; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
                                        <span style="color: #999; font-size: 0.85em; display: block; margin-bottom: 5px;">Prénom</span>
                                        <strong>{{ profilCible.prenom }}</strong>
                                    </div>
                                    <div style="background: white; padding: 15px; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
                                        <span style="color: #999; font-size: 0.85em; display: block; margin-bottom: 5px;">Nom</span>
                                        <strong>{{ profilCible.nom }}</strong>
                                    </div>
                                    <div style="background: white; padding: 15px; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
                                        <span style="color: #999; font-size: 0.85em; display: block; margin-bottom: 5px;">Âge</span>
                                        <strong>{{ profilCible.age }} ans</strong>
                                    </div>
                                    <div style="background: white; padding: 15px; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
                                        <span style="color: #999; font-size: 0.85em; display: block; margin-bottom: 5px;">Genre</span>
                                        <strong>{{ profilCible.genre }}</strong>
                                    </div>
                                </div>
                            {% else %}
                                <div style="text-align: center; color: #999; font-style: italic;">
                                    Le profil détaillé n'a pas encore été renseigné.
                                </div>
                            {% endif %}

                            <div style="text-align: center; margin-top: 20px; color: #777; font-size: 0.9em; background: rgba(255,255,255,0.6); padding: 15px; border-radius: 10px;">
                                <strong>Aide à la modération :</strong><br>
                                Vérifiez que la photo d'identité (à gauche) correspond bien aux informations d'état civil (Prénom, Nom, Âge) renseignées ci-dessus.
                            </div>
                            
                        </div>
                    </div>
                {% endif %}
            </main>
        </div>
    </div>
{% endblock %}