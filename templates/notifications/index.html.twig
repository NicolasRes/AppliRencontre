{% extends 'base.html.twig' %}

{% block title %}Notifications{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/app_design.css') }}">
    <style>
        /* Conteneur principal des notifications */
        .displayNotifs {
            width: 100%;
            max-width: 600px;
            margin: 20px auto;
            padding: 0 15px;
        }

        /* Style de base d'une tuile */
        .notif-tile {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: white;
            padding: 15px 20px;
            margin-bottom: 15px;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            cursor: pointer;
            border-left: 6px solid #ed3692; /* Bordure rose par défaut */
        }

        /* État "Non lu" : Texte noir et gras */
        .notif-unread {
            font-weight: bold;
            color: #000;
        }

        /* État "Lu" : Texte gris et bordure grise */
        .notif-read {
            font-weight: normal;
            color: #888 !important;
            border-left-color: #ddd !important;
            background: #f9f9f9;
        }

        .notif-tile:hover {
            transform: scale(1.02);
            background: #fff1f5;
        }

        /* Contenu textuel */
        .notif-link {
            flex: 1;
            text-decoration: none;
            color: inherit;
        }

        .notif-title {
            font-size: 1.1em;
            margin-bottom: 5px;
            display: block;
        }

        .notif-message {
            font-size: 0.9em;
            margin: 0;
        }

        /* Bouton supprimer (Croix) */
        .notif-delete {
            font-size: 24px;
            color: #ccc;
            text-decoration: none;
            margin-left: 20px;
            line-height: 1;
            transition: color 0.2s;
        }

        .notif-delete:hover {
            color: #ff4d4d;
        }
    </style>
{% endblock %}

{% block body %}
<div class="app-body-reset">
    <div id="date-app-container">
        <aside class="sidebar">
            {{ include('partials/_header_app.html.twig') }}
        </aside>

        <div class="displayNotifs">
            <h1 style="color: white; text-shadow: 1px 1px 3px rgba(0,0,0,0.3); margin-bottom: 30px;">
                Mes Notifications
            </h1>

            {% for notif in notifs %}
                {# On utilise 'notif.lu' défini dans ton Controller  #}
                <div class="notif-tile {{ notif.lu ? 'notif-read' : 'notif-unread' }}">
                    
                    {# Cliquer sur la tuile marque comme lu via la route du Controller  #}
                    <a href="{{ path('app_notification_read', {'id': notif.id}) }}" class="notif-link">
                        <span class="notif-title">
                            {% if notif.type == 0 %}
                                Bienvenue sur Tindr !
                            {% elseif notif.type == 1 %}
                                Vous avez reçu un message
                            {% elseif notif.type == 2 %}
                                Vous avez un match !
                            {% elseif notif.type == -1 %}
                                Vous avez été signalé
                            {% endif %}
                        </span>
                        <p class="notif-message">{{ notif.contenu }}</p>
                    </a>

                    {# Bouton de suppression lié à 'app_notification_delete'  #}
                    <a href="{{ path('app_notification_delete', {'id': notif.id}) }}" 
                       class="notif-delete" 
                       onclick="return confirm('Supprimer définitivement ?')">
                        &times;
                    </a>
                </div>
            {% else %}
                <p style="color: white; text-align: center;">Vous n'avez aucune notification pour le moment.</p>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}