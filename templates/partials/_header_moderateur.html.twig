{# On récupère le nom de la route actuelle #}
{% set current_route = app.request.attributes.get('_route') %}

<a href="{{ path('app_moderateur_signalements') }}" class="sidebar-item" 
   {% if current_route == 'app_moderateur_signalements' %}style="background: #fff1f5;"{% endif %}>
    
    <img class="sidebar-icon" src="{{ asset('images/Notification.webp') }}" alt="Signalements">
    <span {% if current_route == 'app_moderateur_signalements' %}style="font-weight: bold; color: #ed3692;"{% endif %}>
        Signalements
    </span>
</a>

<a href="{{ path('app_moderateur_validations') }}" class="sidebar-item"
   {% if current_route == 'app_moderateur_validations' %}style="background: #fff1f5;"{% endif %}>
    
    <img class="sidebar-icon" src="{{ asset('images/valid.webp') }}" alt="Validations">
    <span {% if current_route == 'app_moderateur_validations' %}style="font-weight: bold; color: #ed3692;"{% endif %}>
        Validations Profils
    </span>
</a>

<div style="margin-top: auto; border-top: 2px solid #180b0b; padding-top: 20px;">
    {# Si tu as le système de sécurité classique de Symfony, la route de déconnexion s'appelle souvent 'app_logout' #}
    <a href="{{ path('app_logout') }}" class="sidebar-item">
        <img class="sidebar-icon" style="border-radius: 50%;" src="{{ asset('images/Denied.jpg') }}" alt="Déconnexion">
        <span>Déconnexion</span>
    </a>
</div>