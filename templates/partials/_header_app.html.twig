{# Recherche de profil depuis la page d'accueil (avec pseudo) #}

{# Le logo est cliquable et renvoie vers l'accueil #}
<a href="{{ path('app_home_page') }}" style="text-decoration: none;">
    <h1 class="tindr-logo">Tindr</h1>
</a>

<form action="{{ path('app_profile_search') }}" method="get">
    <input
        type="text"
        name="pseudo"
        class="search-input"
        placeholder="Recherche..."
    >
</form>

<a href="{{ path('home') }}" class="sidebar-item">
    <img class="sidebar-icon" src="{{ asset('images/Home.jpg') }}" alt="Home">
    <span>Accueil</span>
</a>

<a href="#" class="sidebar-item">
    <img class="sidebar-icon" src="{{ asset('images/Messagerie.png') }}" alt="Msg">
    <span>Messages</span>
</a>

<a href="{{ path('app_notifications') }}" class="sidebar-item">
    <img class="sidebar-icon" src="{{ asset('images/Notification.webp') }}" alt="Notif">
    <span>Notifications</span>
</a>

<a href="#" class="sidebar-item" onclick="menu()">
    <img class="sidebar-icon" src="{{ asset('images/Configuration.webp') }}" alt="Cfg">
    <span>Paramètres</span>
</a>
<ul id="list">
    <li><a href="{{ path('app_informations') }}">Mes informations</a></li>
    <li><a href="{{ path('app_configuration') }}">Mes préférences</a></li>
    <li><a href="{{ path('app_logout') }}">Déconnexion</a></li>
</ul>

<div style="margin-top: auto; border-top: 2px solid #180b0b; padding-top: 20px;">
    <div class="sidebar-item">
        <img class="sidebar-icon" style="border-radius: 50%;"
            src="{{ app.user and app.user.imageIdentite ? asset('uploads/identites/' ~ app.user.imageIdentite) : asset('images/PlaceHolderProfil.jpeg') }}"
            alt="Moi">
        <span>Mon Profil</span>
    </div>
</div>
<script>
    function menu(){
        const list = document.getElementById("list");
        list.classList.toggle("show");
    }
</script>
