{% extends 'conversation/layout.html.twig' %}

{% block body_class %}chat-page{% endblock %}

{% block conversation_content %}
    <!-- Header -->
    <div style="padding: 15px; border-bottom: 1px solid #ddd;">
        <strong>
            {{ conversation ? 'Conversation' : 'Aucune conversation sélectionnée' }}
        </strong>
    </div>

    <!-- Messages -->
    <div style="flex: 1; overflow-y: auto; padding: 20px;" id="messages">

        {% if not conversation %}
            <div style="height: 100%; display: flex; justify-content: center; align-items: center;">
                <p style="color: #777; text-align: center;">
                    💬 Sélectionne une conversation<br>
                    pour commencer
                </p>
            </div>
        {% endif %}

    </div>

    <!-- Input -->
    <div style="padding: 15px; border-top: 1px solid #ddd; display: flex; gap: 10px;">

        <input type="text"
               id="content"
               placeholder="Message"
               style="flex: 1; padding: 10px;"
               {% if not conversation %}disabled{% endif %}>

        <button style="padding: 10px 20px;"
                {% if not conversation %}disabled{% endif %}>
            Envoyer
        </button>

    </div>

{% endblock %}
