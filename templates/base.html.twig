{# templates/base.html.twig #}
<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}RencontreApp{% endblock %}</title>
        
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('css/style.css') }}">
        {% endblock %}

        {% block javascripts %}
            {# {% block importmap %}{{ importmap('app') }}{% endblock %} #}
        {% endblock %}

        <style>
        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        </style>
    </head>

    {# templates/base.html.twig #}
    <body>
        <div class="main-content">
            {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div style="padding: 15px 25px; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.2); font-family: sans-serif; font-weight: bold; animation: slideIn 0.3s ease-out;
                            background-color: {{ label == 'success' ? '#d4edda' : (label == 'warning' ? '#fff3cd' : '#f8d7da') }}; 
                            color: {{ label == 'success' ? '#155724' : (label == 'warning' ? '#856404' : '#721c24') }};">
                    {{ message }}
                </div>
            {% endfor %}
            {% endfor %}
            {% block body %}{% endblock %}
        </div>
    </body>
</html>