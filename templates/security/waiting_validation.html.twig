{% extends 'base.html.twig' %}

{% block title %}Vérification{% endblock %}

{% block body %}
<div class="app-body-reset" style="display: flex; align-items: center; justify-content: center; text-align: center; height: 100vh;">
    <div style="max-width: 450px; padding: 20px;">
        
        <div style="font-size: 100px; margin-bottom: 20px; filter: drop-shadow(0 10px 15px rgba(0,0,0,0.1));">🛡️</div>
        
        <h1 style="color: #2d2d2d; font-size: 2.2rem; margin-bottom: 15px; font-weight: 800; letter-spacing: -1px;">
            Vérification en cours
        </h1>
        
        {% if app.user.status == 'pending' %}
            <p style="color: #444; font-size: 1.2rem; line-height: 1.5; font-weight: 600; margin-bottom: 40px;">
                Patience, <span style="color: #ed3692;">{{ app.user.pseudo }}</span> !<br> 
                Nos modérateurs valident votre profil pour garantir une expérience de qualité.
            </p>
            
            <a href="{{ path('app_logout') }}" 
               style="color: #666; font-weight: 800; text-decoration: none; border: 2px solid #666; padding: 12px 30px; border-radius: 50px; font-size: 0.9rem; transition: all 0.3s;">
                SE DÉCONNECTER
            </a>
        {% endif %}

        {% if app.user.status == 'rejected' %}
             <p style="color: #d63031; font-size: 1.2rem; font-weight: 600;">
                Votre profil a été rejeté. Veuillez modifier vos informations.
            </p>
            <a href="{{ path('app_register') }}" class="btn-modern" style="display: inline-block; margin-top: 20px;">
                Modifier mon profil
            </a>
        {% endif %}
    </div>
</div>
{% endblock %}