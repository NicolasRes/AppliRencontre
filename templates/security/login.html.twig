{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="app-body-reset" style="display: flex; align-items: center; justify-content: center; height: 100vh;">
    <div style="width: 100%; max-width: 350px; padding: 20px; text-align: center;">
        
        <h2 style="color: #2d2d2d; margin-bottom: 40px; font-weight: 800; font-size: 2.2rem; letter-spacing: -1px;">
            Connexion
        </h2>

        <form method="post">
            {% if error %}
                <div style="color: #d63031; background: rgba(255, 255, 255, 0.4); padding: 15px; border-radius: 15px; margin-bottom: 20px; font-size: 0.9rem; font-weight: bold;">
                    Email ou mot de passe incorrect.
                </div>
            {% endif %}

            <div style="margin-bottom: 15px;">
                <input type="email" value="{{ last_username }}" name="email" placeholder="Email" 
                       style="width: 100%; background: white; border: none; padding: 18px; border-radius: 15px; box-sizing: border-box; font-size: 1rem; box-shadow: 0 4px 10px rgba(0,0,0,0.05);" 
                       required autofocus>
            </div>

            <div style="margin-bottom: 30px;">
                <input type="password" name="password" placeholder="Mot de passe" 
                       style="width: 100%; background: white; border: none; padding: 18px; border-radius: 15px; box-sizing: border-box; font-size: 1rem; box-shadow: 0 4px 10px rgba(0,0,0,0.05);" 
                       required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn-modern" style="width: 100%; cursor: pointer; border: none; background: #ed3692; color: white; padding: 18px; border-radius: 50px; font-weight: 900; font-size: 1.1rem; box-shadow: 0 10px 20px rgba(237, 54, 146, 0.3);">
                Se connecter
            </button>
        </form>

        <div style="margin-top: 30px;">
            <a href="{{ path('app_register') }}" style="color: #444; text-decoration: none; font-size: 0.9rem; font-weight: 800;">
                Pas de compte ? <span style="color: #ed3692;">S'inscrire</span>
            </a>
        </div>
    </div>
</div>
{% endblock %}