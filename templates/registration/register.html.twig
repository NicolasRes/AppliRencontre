{# templates/registration/register.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Créer un compte - Tindr{% endblock %}

{% block body %}
<div class="app-body-reset" style="display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 40px 0; overflow-y: auto;">
    <div style="width: 100%; max-width: 500px; padding: 20px;">
        
        <h2 style="text-align: center; color: white; margin-bottom: 30px; font-weight: 800; font-size: 2.2rem; letter-spacing: -1px;">
            Créer un compte
        </h2>

        <div class="auth-container" style="background: rgba(255, 255, 255, 0.95); border-radius: 25px; padding: 35px; box-shadow: 0 15px 35px rgba(0,0,0,0.2);">
            
            {# Affichage des erreurs flash #}
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div style="background: #fff1f5; color: #ed3692; padding: 12px; border-radius: 12px; margin-bottom: 20px; text-align: center; font-weight: bold; font-size: 0.9rem; border: 1px solid #ed3692;">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {{ form_start(registrationForm, {'attr': {'style': 'display: flex; flex-direction: column; gap: 15px;'}}) }}
                
                {# Erreurs globales #}
                <div style="color: #d63031; font-size: 0.85rem;">
                    {{ form_errors(registrationForm) }}
                </div>

                <div class="form-row">
                    {{ form_widget(registrationForm.pseudo, {'attr': {'placeholder': 'Votre pseudo', 'class': 'input-modern'}}) }}
                    <div class="error-text">{{ form_errors(registrationForm.pseudo) }}</div>
                </div>

                <div class="form-row">
                    {{ form_widget(registrationForm.email, {'attr': {'placeholder': 'Email', 'class': 'input-modern'}}) }}
                    <div class="error-text">{{ form_errors(registrationForm.email) }}</div>
                </div>

                <div style="display: flex; gap: 10px;">
                    <div style="flex: 1;">
                        {{ form_widget(registrationForm.prenom, {'attr': {'placeholder': 'Prénom', 'class': 'input-modern'}}) }}
                    </div>
                    <div style="flex: 1;">
                        {{ form_widget(registrationForm.nom, {'attr': {'placeholder': 'Nom', 'class': 'input-modern'}}) }}
                    </div>
                </div>

                <div style="display: flex; gap: 10px; align-items: flex-start;">
                    <div style="flex: 1;">
                        {{ form_label(registrationForm.age, 'Âge', {'label_attr': {'style': 'font-size: 0.8rem; color: #666; margin-left: 10px;'}}) }}
                        {{ form_widget(registrationForm.age, {'attr': {'class': 'input-modern'}}) }}
                        <div class="error-text">{{ form_errors(registrationForm.age) }}</div>
                    </div>
                    <div style="flex: 1;">
                        {{ form_label(registrationForm.genre, 'Genre', {'label_attr': {'style': 'font-size: 0.8rem; color: #666; margin-left: 10px;'}}) }}
                        {{ form_widget(registrationForm.genre, {'attr': {'class': 'input-modern'}}) }}
                        <div class="error-text">{{ form_errors(registrationForm.genre) }}</div>
                    </div>
                </div>

                <div class="form-row">
                    {{ form_widget(registrationForm.plainPassword, {'attr': {'placeholder': 'Mot de passe', 'class': 'input-modern'}}) }}
                    <div class="error-text">{{ form_errors(registrationForm.plainPassword) }}</div>
                </div>

                <div style="background: #f8f8f8; padding: 15px; border-radius: 15px; border: 2px dashed #ddd; margin-top: 5px;">
                    <label style="display: block; font-size: 0.85rem; color: #555; font-weight: bold; margin-bottom: 8px;">
                        📸 Photo d'identité (Vérification)
                    </label>
                    {{ form_widget(registrationForm.imageIdentite, {'attr': {'style': 'font-size: 0.8rem;'}}) }}
                    <div class="error-text">{{ form_errors(registrationForm.imageIdentite) }}</div>
                </div>

                <button type="submit" class="btn-modern-submit">
                    S'INSCRIRE
                </button>
            {{ form_end(registrationForm) }}

            <div style="text-align: center; margin-top: 25px;">
                <a href="{{ path('app_login') }}" style="color: #666; text-decoration: none; font-size: 0.9rem; font-weight: 700;">
                    Déjà membre ? <span style="color: #ed3692;">Se connecter</span>
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    /* Inputs stylisés */
    .input-modern {
        width: 100%;
        background: #f0f2f5;
        border: 2px solid transparent;
        padding: 14px 18px;
        border-radius: 15px;
        box-sizing: border-box;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        outline: none;
    }

    .input-modern:focus {
        background: white;
        border-color: #ed3692;
        box-shadow: 0 0 0 4px rgba(237, 54, 146, 0.1);
    }

    /* Bouton d'inscription */
    .btn-modern-submit {
        margin-top: 10px;
        width: 100%;
        background: linear-gradient(to right, #ff6b6b, #ed3692);
        color: white;
        border: none;
        padding: 16px;
        border-radius: 50px;
        font-weight: 900;
        font-size: 1.1rem;
        letter-spacing: 1px;
        box-shadow: 0 10px 20px rgba(237, 54, 146, 0.3);
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-modern-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 25px rgba(237, 54, 146, 0.4);
        filter: brightness(1.05);
    }

    .error-text ul {
        list-style: none;
        padding: 0;
        margin: 5px 0 0 10px;
        color: #d63031;
        font-size: 0.75rem;
        font-weight: bold;
    }
</style>
{% endblock %}